<div style="background:#0f172a; min-height:100vh; color:white; font-family:sans-serif; padding:24px 16px 90px;">
  <div style="max-width:540px; margin:0 auto;">
    <div style="background:#111827; border:1px solid #1f2937; border-radius:14px; padding:22px; margin-bottom:18px;">
      <div style="display:flex; align-items:center; gap:14px;">
        <div style="width:64px; height:64px; border-radius:50%; background:linear-gradient(45deg,#22d3ee,#9333ea); display:flex; align-items:center; justify-content:center; font-size:28px; font-weight:bold;">
          <%= @user.email.first.upcase %>
        </div>
        <div>
          <h1 style="margin:0; font-size:20px; color:#e0f2fe;">Meu perfil</h1>
          <p style="margin:6px 0 0; color:#94a3b8;"><%= @user.email %></p>
        </div>
      </div>

      <div style="margin-top:18px; display:flex; gap:10px;">
        <div style="background:#1f2937; border-radius:10px; padding:10px 14px;">
          <strong style="display:block; color:#22d3ee;"><%= @posts.count %></strong>
          <small style="color:#94a3b8;">publicações</small>
        </div>
      </div>
    </div>

    <div style="background:#111827; border:1px solid #1f2937; border-radius:14px; padding:16px;">
      <h2 style="margin:0 0 12px; font-size:16px; color:#e0f2fe;">Minhas publicações</h2>

      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <div style="border-top:1px solid #1f2937; padding:12px 0;">
            <p style="margin:0; color:#e2e8f0; font-weight:600;"><%= post.title %></p>
            <p style="margin:6px 0 0; color:#94a3b8; font-size:13px;"><%= truncate(post.description, length: 90) %></p>
          </div>
        <% end %>
      <% else %>
        <p style="color:#64748b; margin:0;">Você ainda não publicou nada.</p>
      <% end %>
    </div>

    <div style="text-align:center; margin-top:16px;">
      <%= link_to "← Voltar ao feed", posts_path, style:"color:#22d3ee; text-decoration:none;" %>
    </div>
  </div>
</div>