<div style="background:#0f172a; min-height:100vh; color:white; font-family:sans-serif;">

  <!--  STORIES -->
  <div style="display:flex; overflow-x:auto; padding:15px; border-bottom:1px solid #1f2937;">
    
    <% @posts.each do |post| %>
      <div style="text-align:center; margin-right:15px;">
        <div style="width:60px; height:60px; border-radius:50%; background:linear-gradient(45deg,#22d3ee,#9333ea); padding:2px;">
          <div style="width:100%; height:100%; border-radius:50%; background:#111827;"></div>
        </div>
        <small style="font-size:12px;">
          <%= post.user.email.split("@").first %>
        </small>
      </div>
    <% end %>

  </div>

  <!--  FEED -->
  <div style="max-width:500px; margin:auto;">

    <% @posts.each do |post| %>

      <div style="margin-bottom:30px; background:#111827; border-radius:10px;">

        <!--  HEADER -->
        <div style="display:flex; align-items:center; padding:10px;">
          <div style="width:40px; height:40px; border-radius:50%; background:#22d3ee; margin-right:10px;"></div>
          <strong><%= post.user.email %></strong>
        </div>

        <!--  IMAGEM -->
        <% if post.respond_to?(:image) && post.image.attached? %>
          <%= image_tag post.image, style: "width:100%; height:300px; object-fit:cover;" %>
        <% else %>
          <!-- imagem fake -->
          <img src="https://picsum.photos/500/300" style="width:100%;">
        <% end %>

        <!--  AÇÕES -->
        <div style="padding:10px;">
          <p style="font-size:20px;"></p>

          <!--  DESCRIÇÃO -->
          <p>
            <strong><%= post.user.email %></strong>
            <%= post.description %>
          </p>

          <!--  DATA -->
          <small style="color:gray;">
            <%= post.created_at.strftime("%d/%m/%Y") %>
          </small>
        </div>

      </div>

    <% end %>

  </div>

  <!--  NAVBAR (tipo Instagram) -->
  <div style="position:fixed; bottom:0; width:100%; background:#111827; display:flex; justify-content:space-around; padding:15px; border-top:1px solid #1f2937;">
    
    <%= link_to posts_path, style:"color:white; text-decoration:none;" do %>
      🏠
    <% end %>

    <%= link_to new_post_path, style:"color:#22d3ee; text-decoration:none;" do %>
      
    <% end %>

    <%= link_to "#", style:"color:white;" do %>
      
    <% end %>

  </div>

</div>