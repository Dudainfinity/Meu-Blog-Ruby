<div style="display:flex; justify-content:flex-start; align-items:center; min-height:100vh; padding-left:120px; position:relative; overflow:hidden; background:radial-gradient(circle at top left, var(--accent-soft), transparent 28%), radial-gradient(circle at bottom right, var(--blue-blur), transparent 30%), linear-gradient(135deg, var(--bg-main) 0%, var(--bg-secondary) 45%, var(--bg-card) 100%);">

  <div style="position:absolute; left:-120px; top:80px; width:280px; height:280px; background:var(--accent-blur); filter:blur(70px); border-radius:50%;"></div>
  <div style="position:absolute; right:180px; bottom:60px; width:260px; height:260px; background:var(--blue-soft); filter:blur(70px); border-radius:50%;"></div>

  <div style="position:absolute; left:120px; top:55px; z-index:1; max-width:520px;">
    <h1 style="margin:0; font-size:56px; line-height:1.05; color:var(--text-primary); letter-spacing:-2px; text-shadow:0 0 30px var(--accent-glow);">
      Rede Social<br>dos Devs
    </h1>
    <p style="margin:14px 0 0; color:var(--text-secondary); font-size:18px;">
      Conecte ideias, projetos e pessoas do mundo da programação.
    </p>
  </div>

  <div style="position:relative; z-index:1; margin-top:150px; background:var(--card-bg-glass); padding:40px; border-radius:15px; width:350px; box-shadow:0 0 30px rgba(0,255,255,0.1); backdrop-filter:blur(4px);">

    <h2 style="text-align:center; color:var(--accent); margin-bottom:20px;">
      🔐 Entrar
    </h2>

    <p style="text-align:center; color:var(--text-muted); margin-bottom:30px;">
      Faça login para continuar 💻
    </p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div style="margin-bottom:15px;">
        <%= f.label :email, style: "color:var(--text-muted);" %><br>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              style: "width:100%; padding:10px; border:none; border-radius:8px; background:var(--bg-input); color:var(--white);" %>
      </div>

      <div style="margin-bottom:15px;">
        <%= f.label :password, style: "color:var(--text-muted);" %><br>
        <%= f.password_field :password, autocomplete: "current-password",
              style: "width:100%; padding:10px; border:none; border-radius:8px; background:var(--bg-input); color:var(--white);" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div style="margin-bottom:20px; color:var(--text-muted);">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me %>
        </div>
      <% end %>

      <div>
        <%= f.submit "Entrar",
              style: "width:100%; padding:12px; background:var(--accent); border:none; border-radius:8px; color:var(--black); font-weight:bold; cursor:pointer;" %>
      </div>

    <% end %>

    <div style="margin-top:20px; text-align:center; color:var(--text-muted);">
      <%= render "users/shared/links" %>
    </div>

  </div>
</div>

<div style="position:fixed; right:400px; top:56%; transform:translateY(-50%); width:300px; background:rgba(2,6,23,0.92); color:#22d3ee; padding:18px; border-radius:10px; font-family:monospace; font-size:12px; box-shadow:0 0 20px rgba(0,255,255,0.15); backdrop-filter:blur(4px);">

<pre>
<span style="color:#22c55e;">token</span> = session[:auth_token]

<span style="color:#22c55e;">if</span> token.present?
  puts <span style="color:#facc15;">"Sessão protegida"</span>
<span style="color:#22c55e;">end</span>
</pre>

</div>

<div style="position:fixed; right:20px; top:42%; transform:translateY(-50%); width:400px; background:rgba(2,6,23,0.92); color:#22d3ee; padding:20px; border-radius:10px; font-family:monospace; font-size:13px; box-shadow:0 0 20px rgba(0,255,255,0.2); backdrop-filter:blur(4px);">

<pre>
<span style="color:#22c55e;">class</span> User
  <span style="color:#22c55e;">def</span> login
    email = <span style="color:#facc15;">"user@email.com"</span>
    password = <span style="color:#facc15;">"******"</span>

    <span style="color:#22c55e;">if</span> authenticate(email, password)
      start_session
      puts <span style="color:#facc15;">"Login realizado com sucesso "</span>
    <span style="color:#22c55e;">else</span>
      puts <span style="color:#ef4444;">"Email ou senha inválidos"</span>
    <span style="color:#22c55e;">end</span>
  <span style="color:#22c55e;">end</span>
<span style="color:#22c55e;">end</span>
</pre>

</div>

<div style="position:fixed; right:460px; bottom:110px; width:300px; background:rgba(2,6,23,0.92); color:#22d3ee; padding:30px; border-radius:25px; font-family:monospace; font-size:12px; box-shadow:0 0 50px rgba(0,255,255,0.15); backdrop-filter:blur(4px);">

<pre>
<span style="color:#22c55e;">def</span> redirect_after_acessos
  path = <span style="color:#facc15;">"/dashboard"</span>
  flash[:notice] = <span style="color:#facc15;">"Esqueceu a senha!!"</span>

  navigate_to(path)
<span style="color:#22c55e;">end</span>
</pre>

</div>

<div style="position:fixed; right:30px; bottom:200px; width:400px; background:rgba(2,6,23,0.92); color:#22d3ee; padding:18px; border-radius:10px; font-family:monospace; font-size:12px; box-shadow:0 0 20px rgba(0,255,255,0.15); backdrop-filter:blur(4px);">

<pre>
<span style="color:#22c55e;">def</span> redirect_after_login
  path = <span style="color:#facc15;">"/posts"</span>
  flash[:notice] = <span style="color:#facc15;">"Bem-vindo de volta!"</span>

  navigate_to(path)
<span style="color:#22c55e;">end</span>
</pre>

</div>
