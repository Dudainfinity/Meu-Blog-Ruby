<div style="background:#0f172a; min-height:100vh; font-family:sans-serif; display:flex; align-items:center; justify-content:center; padding:20px;">

  <div style="background:#111827; padding:28px; border-radius:14px; width:100%; max-width:460px; border:1px solid #1f2937;">

    <h2 style="color:#22d3ee; margin:0 0 22px; font-size:20px; display:flex; align-items:center; gap:8px;">
      📸 Nova publicação
    </h2>

    <%= form_with model: @post, html: { enctype: "multipart/form-data" } do |f| %>

      <% if @post.errors.any? %>
        <div style="background:#ef444420; border:1px solid #ef4444; border-radius:8px; padding:10px; margin-bottom:16px;">
          <% @post.errors.full_messages.each do |msg| %>
            <p style="color:#ef4444; margin:4px 0; font-size:13px;">⚠️ <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <!-- IMAGEM -->
      <div style="margin-bottom:16px;">
        <label style="display:block; color:#94a3b8; margin-bottom:8px; font-size:13px;">📷 Foto</label>
        <div id="preview-wrapper" style="width:100%; height:220px; background:#1e293b; border:2px dashed #334155; border-radius:10px; display:flex; align-items:center; justify-content:center; overflow:hidden; margin-bottom:8px; cursor:pointer; position:relative;" onclick="document.getElementById('img-input').click()">
          <img id="preview-img" src="" style="width:100%; height:100%; object-fit:cover; display:none;">
          <div id="preview-placeholder" style="text-align:center; color:#475569;">
            <div style="font-size:36px;">🖼️</div>
            <div style="font-size:13px; margin-top:6px;">Clique para escolher uma foto</div>
          </div>
        </div>
        <%= f.file_field :image, id:"img-input", accept:"image/*",
            style:"display:none;",
            onchange:"previewImage(event)" %>
      </div>

      <!-- TÍTULO -->
      <div style="margin-bottom:14px;">
        <%= f.label :title, "Título", style:"display:block; color:#94a3b8; margin-bottom:6px; font-size:13px;" %>
        <%= f.text_field :title,
            placeholder: "Dê um título ao post...",
            style:"width:100%; padding:10px 12px; background:#1f2937; border:1px solid #374151; border-radius:8px; color:white; font-size:14px; box-sizing:border-box; outline:none;" %>
      </div>

      <!-- DESCRIÇÃO -->
      <div style="margin-bottom:20px;">
        <%= f.label :description, "Legenda", style:"display:block; color:#94a3b8; margin-bottom:6px; font-size:13px;" %>
        <%= f.text_area :description, rows: 3,
            placeholder: "Escreva uma legenda...",
            style:"width:100%; padding:10px 12px; background:#1f2937; border:1px solid #374151; border-radius:8px; color:white; font-size:14px; box-sizing:border-box; resize:none; outline:none;" %>
      </div>

      <%= f.submit "Publicar",
          style:"width:100%; padding:12px; background:#22d3ee; color:#020617; font-weight:bold; border:none; border-radius:8px; cursor:pointer; font-size:15px;" %>

    <% end %>

    <div style="text-align:center; margin-top:16px;">
      <%= link_to "← Voltar ao feed", posts_path, style:"color:#475569; font-size:13px;" %>
    </div>

  </div>

</div>

<script>
  function previewImage(event) {
    const file = event.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(e) {
      const img = document.getElementById('preview-img');
      const placeholder = document.getElementById('preview-placeholder');
      img.src = e.target.result;
      img.style.display = 'block';
      placeholder.style.display = 'none';
    };
    reader.readAsDataURL(file);
  }
</script>
